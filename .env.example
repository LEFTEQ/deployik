# Required
JWT_SECRET=
ENCRYPTION_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional
ALLOWED_GITHUB_USERS=your-github-username
# HTTP port for the Go server. Serves both the API (/api/*) and the embedded
# React SPA (all other routes) — no separate frontend server needed in production.
PORT=8080
DATABASE_PATH=/data/deployik.db
DATA_DIR=/data
NGINX_CONF_DIR=/opt/nginx-proxy/conf.d
BUILD_DIR=/tmp/deployik-builds
VPS_HOST=203.0.113.10

# ── Proxy Configuration ─────���────────────────────────────────────────────────
#
# PROXY_TYPE controls how Deployik reaches deployed containers:
#   docker    (default) — nginx-proxy runs as a Docker container on the same
#                         Docker network; containers are reachable by name.
#                         Reload: docker exec {PROXY_CONTAINER_NAME} nginx -s reload
#   host-port — Deployik binds each container's port 3000 to a random localhost
#               port. Use this when your proxy (Apache, nginx) runs on the host.
#               Reload: PROXY_RELOAD_CMD (see below)
# PROXY_TYPE=docker

# PROXY_CONFIG_FORMAT controls the config file format written to NGINX_CONF_DIR:
#   nginx   (default) — nginx server block (for nginx-proxy container or host nginx)
#   apache  — Apache VirtualHost block (for Apache2 on the host)
# PROXY_CONFIG_FORMAT=nginx

# PROXY_RELOAD_CMD is passed to `sh -c`, so you can use quoted args, pipes,
# && chains, and env expansion. Only used when PROXY_TYPE=host-port.
# Examples:
#   apachectl graceful                         — Apache on Debian/Ubuntu
#   nginx -s reload                            — host nginx
#   sudo -n systemctl reload nginx             — via sudo (passwordless)
#   nsenter -t 1 -m -- apachectl graceful      — reach host from container
#   bash -c 'apachectl configtest && apachectl graceful'  — test then reload
# PROXY_RELOAD_CMD=apachectl graceful

# PROXY_SSL_CERT / PROXY_SSL_KEY — optional paths to an existing wildcard cert.
# Useful when PROXY_CONFIG_FORMAT=apache, so Deployik can write vhosts for any
# subdomain without running certbot per-domain.
# Example (wildcard *.example.com via Let's Encrypt):
# PROXY_SSL_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
# PROXY_SSL_KEY=/etc/letsencrypt/live/example.com/privkey.pem
