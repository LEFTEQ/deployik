# =============================================================================
# Deployik configuration — copy this file to `.env` and fill in the values.
#   cp .env.example .env
# scripts/bootstrap.sh can generate JWT_SECRET / ENCRYPTION_KEY for you.
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# Signs JWT access tokens and site-auth cookies. Use a long random string:
#   openssl rand -hex 32
JWT_SECRET=

# Derives the AES-256-GCM key that encrypts GitHub tokens, env vars, secrets,
# webhook secrets, and passwords at rest. Use a long random string:
#   openssl rand -hex 32
# WARNING: changing this after data exists makes existing encrypted values
# undecryptable. Set it once and keep it safe.
ENCRYPTION_KEY=

# GitHub OAuth App credentials. Create an OAuth App at
# https://github.com/settings/developers with the callback URL
# <FRONTEND_URL>/auth/callback and scopes repo, read:user, admin:repo_hook.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Base domain you control, used to mint auto preview domains
# (e.g. my-app.preview.<BASE_DOMAIN>). REQUIRED in production — Deployik refuses
# to start without it (or PREVIEW_DOMAIN_SUFFIX) outside DEV_MODE. You need a
# wildcard DNS A-record (*.preview.<BASE_DOMAIN>) pointing at this server.
BASE_DOMAIN=example.com
# Override the full preview suffix directly instead of deriving preview.<BASE_DOMAIN>:
# PREVIEW_DOMAIN_SUFFIX=preview.example.com

# Public URL of the Deployik dashboard. Drives the OAuth callback, webhook URL,
# CORS allowlist, and the Secure flag on cookies. MUST be the real external URL
# (https://...) in production or OAuth and cross-origin requests will break.
FRONTEND_URL=https://deployik.example.com

# ── Access control ───────────────────────────────────────────────────────────

# Comma-separated GitHub usernames allowed to sign in. Empty = anyone with a
# GitHub account can sign in (lock this down on a public-facing instance).
ALLOWED_GITHUB_USERS=your-github-username

# Comma-separated GitHub usernames granted admin. If unset, the first user to
# sign in is auto-promoted to admin.
ADMIN_GITHUB_USERS=your-github-username

# Additional allowed CORS origins (comma-separated). FRONTEND_URL is always
# allowed; add others here if needed.
# ALLOWED_ORIGINS=

# ── Server / storage ─────────────────────────────────────────────────────────

# HTTP port for the Go server. Serves both the API (/api/*) and the embedded
# React SPA (all other routes) — no separate frontend server needed in production.
PORT=8080
DATABASE_PATH=/data/deployik.db
DATA_DIR=/data
# Where deployment screenshots are stored (defaults to <DATA_DIR>/screenshots).
# SCREENSHOT_DIR=/data/screenshots
# Temp dir for git clones + builds (cleaned after each deploy).
BUILD_DIR=/tmp/deployik-builds

# ── DNS / SSL ────────────────────────────────────────────────────────────────

# Public IP of THIS server. Shown in the dashboard's DNS setup guide and used to
# verify that custom domains' A-records point here. Set it to your VPS IP.
VPS_HOST=

# Email used when registering Let's Encrypt certificates.
SSL_EMAIL=admin@example.com

# Where Deployik writes generated proxy vhosts (mounted into the nginx-proxy
# container). The docker-compose maps the host dir to this path.
NGINX_CONF_DIR=/opt/nginx-proxy/conf.d
# Host paths to the proxy's Let's Encrypt certs + ACME challenge webroot.
PROXY_CERTS_DIR=/opt/nginx-proxy/certs
PROXY_HTML_DIR=/opt/nginx-proxy/html
# Name of the nginx-proxy container, used for `docker exec <name> nginx -s reload`.
PROXY_CONTAINER_NAME=nginx-proxy

# ── Proxy Configuration ──────────────────────────────────────────────────────
#
# PROXY_TYPE controls how Deployik reaches deployed containers:
#   docker    (default) — nginx-proxy runs as a Docker container on the same
#                         Docker network; containers are reachable by name.
#                         Reload: docker exec {PROXY_CONTAINER_NAME} nginx -s reload
#   host-port — Deployik binds each container's port 3000 to a random localhost
#               port. Use this when your proxy (Apache, nginx) runs on the host.
#               Reload: PROXY_RELOAD_CMD (see below)
# PROXY_TYPE=docker

# PROXY_CONFIG_FORMAT controls the config file format written to NGINX_CONF_DIR:
#   nginx   (default) — nginx server block (for nginx-proxy container or host nginx)
#   apache  — Apache VirtualHost block (for Apache2 on the host)
# PROXY_CONFIG_FORMAT=nginx

# PROXY_HTTP3 (nginx format only) adds HTTP/3 (QUIC) listeners and the Alt-Svc
# discovery header to every generated vhost. Before enabling, make sure:
#   - the proxy nginx is built with http_v3_module (nginx -V | grep http_v3)
#   - UDP 443 is published on the proxy container and open in the firewall
#   - exactly one `listen 443 quic reuseport;` exists somewhere outside the
#     generated configs (e.g. a default_server conf) — Deployik never emits
#     reuseport itself, nginx allows it only once per address:port
#   - a `geo $h3_alt_svc { ... }` map exists at http{} level so generated vhosts
#     can emit `add_header Alt-Svc $h3_alt_svc always;`; nginx fails the config
#     test if the variable is undefined
# PROXY_HTTP3=false

# PROXY_RELOAD_CMD is passed to `sh -c`, so you can use quoted args, pipes,
# && chains, and env expansion. Only used when PROXY_TYPE=host-port.
# Examples:
#   apachectl graceful                         — Apache on Debian/Ubuntu
#   nginx -s reload                            — host nginx
#   sudo -n systemctl reload nginx             — via sudo (passwordless)
#   nsenter -t 1 -m -- apachectl graceful      — reach host from container
#   bash -c 'apachectl configtest && apachectl graceful'  — test then reload
# PROXY_RELOAD_CMD=apachectl graceful

# PROXY_SSL_CERT / PROXY_SSL_KEY — optional paths to an existing wildcard cert.
# When set, Deployik writes vhosts (nginx or apache) that reference this cert for
# any domain PROXY_SSL_WILDCARD_DOMAINS marks as covered, without running certbot
# per-domain. Example (wildcard *.preview.example.com via Let's Encrypt DNS-01):
# PROXY_SSL_CERT=/etc/nginx/certs/live/wildcard.preview.example.com/fullchain.pem
# PROXY_SSL_KEY=/etc/nginx/certs/live/wildcard.preview.example.com/privkey.pem

# PROXY_SSL_WILDCARD_DOMAINS — comma-separated base domains the PROXY_SSL_CERT
# wildcard covers (e.g. preview.example.com). A single-label subdomain of one of
# these is served the wildcard cert and skips per-domain certbot; everything else
# keeps the per-domain Let's Encrypt flow. Empty = wildcard matching off.
# See docs/runbooks/wildcard-preview-cert.md.
# PROXY_SSL_WILDCARD_DOMAINS=preview.example.com

# ── Optional integrations ────────────────────────────────────────────────────

# Public URL GitHub posts webhooks to (defaults to <FRONTEND_URL>/api/webhooks/github).
# WEBHOOK_URL=

# Audience analytics via a self-hosted Umami instance (optional).
# ANALYTICS_UMAMI_URL=
# ANALYTICS_UMAMI_PUBLIC_URL=
# ANALYTICS_UMAMI_SCRIPT_URL=
# ANALYTICS_UMAMI_USERNAME=
# ANALYTICS_UMAMI_PASSWORD=
# Runtime analytics via a Loki instance (optional).
# ANALYTICS_LOKI_URL=

# Bearer token gating GET /api/monitoring/targets (Prometheus http_sd discovery).
# Unset = endpoint disabled (404). Set to a shared secret to enable external
# production uptime monitoring.
# MONITORING_TOKEN=

# Set to `true` to allow startup without the required secrets; enables the
# dev-login endpoint and mock GitHub data. NEVER set this in production.
# DEV_MODE=false
