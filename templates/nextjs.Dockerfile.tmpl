# Auto-generated by Deployik for Next.js standalone deployment
FROM node:{{.NodeVersion}}-alpine AS base
WORKDIR /app

# Install dependencies
FROM base AS deps
COPY package.json {{if .HasBunLock}}bun.lockb{{else if .HasPnpmLock}}pnpm-lock.yaml{{else}}package-lock.json{{end}} ./
{{if .UseBun}}RUN npm i -g bun && bun install --frozen-lockfile
{{else if .UsePnpm}}RUN corepack enable && pnpm install --frozen-lockfile
{{else}}RUN npm ci
{{end}}

# Build
FROM base AS builder
COPY --from=deps /app/node_modules ./node_modules
COPY . .
{{range .BuildEnvVars}}ENV {{.Key}}={{.Value}}
{{end}}
RUN {{.BuildCommand}}

# Production runtime
FROM base AS runner
ENV NODE_ENV=production
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
CMD ["node", "server.js"]
